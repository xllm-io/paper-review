---
interface Props {
  tag: string;
  size?: "sm" | "md";
}
const { tag, size = "sm" } = Astro.props;
---

<a
  href={`/tags/${tag}`}
  class:list={[
    "inline-flex items-center rounded-full bg-base-100 text-base-700 ring-1 ring-base-200 hover:bg-base-200 hover:text-base-900 transition-colors duration-200",
    size === "sm" ? "px-2.5 py-0.5 text-xs" : "px-3 py-1 text-sm",
  ]}
>
  {tag}
</a>
