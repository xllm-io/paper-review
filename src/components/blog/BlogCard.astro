---
import TagBadge from "@/components/blog/TagBadge.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  image?: ImageMetadata;
}
const { title, description, date, tags, slug, image } = Astro.props;
const base = import.meta.env.BASE_URL;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`${base}blog/${slug}`} class="block group">
  <article class="bg-white p-8 rounded-3xl hover:ring-1 hover:ring-base-200 transition-all duration-200">
    {image && (
      <div class="mb-4 overflow-hidden rounded-2xl">
        <img
          src={image.src}
          alt={title}
          class="w-full h-48 object-cover group-hover:scale-[1.02] transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )}
    <div class="flex items-center gap-2 text-xs text-base-500">
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h2 class="text-xl tracking-tight text-base-900 font-medium mt-2 group-hover:text-base-700 transition-colors">
      {title}
    </h2>
    <p class="text-sm text-base-600 mt-2 line-clamp-2">{description}</p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-4">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    )}
  </article>
</a>
