---
import Logo from "@/components/assets/Logo.astro";
---

<div class="fixed bottom-4 inset-x-0 z-50  px-8">
  <div
    class="w-fit mx-auto flex items-center gap-4 justify-between p-1 bg-white rounded-full shadow-lg outline outline-base-100"
  >
    <a class="text-base-900" href="/">
      <Logo class="h-8" />
    </a>
    <div class="flex items-center gap-2 text-xs font-medium">
      <button
        id="search-trigger"
        class="text-base-500 hover:text-base-900 transition-colors p-1"
        aria-label="Search articles"
      >
        <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" />
          <path stroke-linecap="round" d="M21 21l-4.35-4.35" />
        </svg>
      </button>
      <a
        href="/blog"
        class="text-base-500 hover:text-base-900 transition-colors"
      >
        Blog
      </a>
      <a
        href="/tags"
        class="text-base-500 hover:text-base-900 transition-colors"
      >
        Tags
      </a>
      <a
        href="https://github.com/michael-andreuzza/minimalstudio"
        class="py-2 w-auto px-4 h-8 rounded-full bg-base-100 font-medium hover:bg-transparent text-base-900 duration-200 focus:ring-offset-2 hover: text-base-900 inline-flex items-center justify-center ring-2 ring-transparent focus:ring-black ring-transparent"
      >
        GitHub</a
      >
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("search-trigger")?.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-search"));
    });
  });
</script>
