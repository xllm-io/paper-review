---
import BigLogo from "@/components/assets/BigLogo.astro";
---

<section class="overflow-hidden relative">
  <BigLogo class="lg:-mx-4 opacity-4 absolute inset-0" />
  <div class="py-12 max-w-3xl mx-auto px-4 lg:px-8 relative">
    <div>
      <span
        class="inline-flex items-center justify-center gap-2 rounded-full px-3 h-7.5 text-xs text-base-900 bg-white ring-inset"
      >
        <p>Paper Review</p>
        <div class="size-2 rounded-full bg-black border-2 border-black"></div>
      </span>
      <h1 class="text-4xl mt-12 tracking-tight text-base-900 text-balance font-medium">
        Summarizing key ideas from LLM and systems research.
      </h1>
    </div>
    <div
      class="grid grid-cols-1 text-base text-base-600 lg:grid-cols-2 max-w-xl gap-2 group h-full mt-12"
    >
      <p>
        Concise reviews of papers on long-context inference, sparse attention, distributed training, and efficient serving.
      </p>
      <p>
        Formulas, figures, and key takeaways — distilled for quick reading and future reference.
      </p>
    </div>
  </div>
</section>
